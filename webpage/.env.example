# Firebase Admin credentials for chat endpoints (local dev only).
# Copy values into .env.local or User environment variables.
# Never commit real secrets.

# Option 1: inline service account JSON string.
# Do NOT commit this value.
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Option 2 (recommended for local dev): absolute path to a local JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=C:\secure\firebase-admin-service-account.json

# Optional project override. If empty, project_id from service account is used.
FIREBASE_PROJECT_ID=
